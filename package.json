{
  "name": "fatemirror-mvp",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ignore-pattern coverage --ignore-pattern .tmp-reading-tests",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:legacy": "node scripts/run-reading-engine-tests.mjs",
    "evaluate:advice": "node scripts/evaluate-advice.mjs --mode=mock",
    "evaluate:advice:mock": "node scripts/evaluate-advice.mjs --mode=mock",
    "evaluate:advice:live": "node scripts/evaluate-advice.mjs --mode=live",
    "evaluate:advice:report": "node scripts/evaluate-advice.mjs --mode=report",
    "beta:invites:batch": "node scripts/create-beta-invite-batch.mjs",
    "cleanup:expired-reports": "node scripts/cleanup-expired-reports.mjs --apply",
    "cleanup:expired-reports:dry-run": "node scripts/cleanup-expired-reports.mjs --dry-run",
    "cleanup:expired-reports:apply": "node scripts/cleanup-expired-reports.mjs --apply",
    "verify:deployment": "node scripts/verify-deployment.mjs",
    "verify:deployment:local": "node scripts/verify-deployment.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.106.2",
    "lunar-javascript": "^1.7.7",
    "next": "16.2.6",
    "openai": "^6.42.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
